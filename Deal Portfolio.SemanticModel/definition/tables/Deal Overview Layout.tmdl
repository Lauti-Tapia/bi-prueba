				      " ", STRING,
				      {
				          {4,  "Financial Metrics", "Target Gross IRR (%)"},
				          {5,  "Financial Metrics", "Target Gross Cash Multiple"},
				          {6,  "Financial Metrics", "Target Levered IRR (%)"},
				          {7,  "Financial Metrics", "Target Levered Cash Multiple"},
				          {8,  "Deal Structure",    "Loan Type"},
