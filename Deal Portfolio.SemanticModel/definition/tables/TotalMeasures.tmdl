	measure 'Debt Yield (%)' =
			
			VAR _Act = CALCULATE([Debt Yield], 'Deal Financials'[Category] = "ACT") -- Ajustar filtro ACT
			VAR _UW  = CALCULATE([Debt Yield], 'Deal Financials'[Category] = "UW") -- Ajustar filtro UW
			RETURN
			    IF(
			        _UW = 0,
			        BLANK(),
			        DIVIDE(_Act, _UW) - 1
			    )
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 4a337866-927c-48d8-b92e-1b987054a967

	measure 'DSCR (%)' =
			
			VAR _Act = CALCULATE([DSCR], 'Deal Financials'[Category] = "ACT")
			VAR _UW  = CALCULATE([DSCR], 'Deal Financials'[Category] = "UW")
			RETURN
			    IF(
			        _UW = 0,
			        BLANK(),
			        DIVIDE(_Act, _UW) - 1
			    )
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 84bbfbfb-a244-4c73-837e-1a11801942f6

	measure 'Occupancy Rate' = ```

			VAR _GPR =
			    CALCULATE(
			        SUM( 'Deal Financials'[Amount] ),
			        'Deal Financials'[Internal Line Item] = "Gross Potential Rent"
			    )
			VAR _Vacancy =
			    CALCULATE(
			        SUM( 'Deal Financials'[Amount] ),
			        'Deal Financials'[Internal Line Item] = "Vacancy"
			    )
			RETURN
			    DIVIDE( _GPR + _Vacancy, _GPR, 0 )
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: f1a2b3c4-d5e6-7890-abcd-ef1234500001

	measure 'BG Color (P&L)' =

			VAR t = SELECTEDVALUE('Report Layout'[RowType])
			RETURN
			SWITCH(
			    TRUE(),
			    t = "Header",   "#0D3B66",   -- azul oscuro
			    t = "Highlight","#1B5E20",   -- verde (NOI / Cash Flow)
			    t = "Subtotal", "#E8E8E8",   -- gris claro
			    BLANK()
			)
		lineageTag: 208bf302-2620-40c9-a386-df4a90d87589

	measure 'Font Color (P&L)' =
			
			VAR t = SELECTEDVALUE('Report Layout'[RowType])
			RETURN
			SWITCH(
			    TRUE(),
			    t = "Header",   "#FFFFFF",
			    t = "Highlight","#FFFFFF",
			    "#000000"
			)
		lineageTag: 9a7ce77b-137b-4ef2-b6d2-bc5b51496917

	measure Comments = ```
			
			
			VAR CurrentItem = SELECTEDVALUE( 'Report Layout'[ ] )
			
			VAR CurrentRowType = SELECTEDVALUE( 'Report Layout'[RowType] )
			 
			VAR _Result = 
			
			    SWITCH(
			
			        TRUE(),
			
			        -- 1. Si es un Encabezado, devolvemos blanco
			
			        CurrentRowType = "Header", BLANK(),
			 
			        -- 2. Si es un Subtotal calculado (que no existe en la base de datos), devolvemos blanco.
			
			        -- (Ej: NOI, Cash Flow, Adjusted GPR no suelen tener un comentario en la tabla origen)
			
			        CurrentItem IN { 
			
			            "Adjusted Gross Potential Rent", 
			
			            "Effective Rental Income", 
			
			            "Effective Gross Revenue", 
			
			            "Total Controllable Expenses", 
			
			            "Total Operating Expenses", 
			
			            "Net Operating Income", 
			
			            "Cash Flow from Operations" 
			
			        }, BLANK(),
			 
			        -- 3. Para todo lo demás (Filas de Data), buscamos el comentario exacto
			
			        CALCULATE(
			
			            -- SELECTEDVALUE trae el texto si es único. 
			
			            -- Si tienes varios comentarios para un mismo ítem, usa FIRSTNONBLANK o CONCATENATEX.
			
			            SELECTEDVALUE( 'Deal Financials'[Comments] ),
			
			            'Deal Financials'[Internal Line Item] = CurrentItem
			
			        )
			
			    )
			 
			RETURN
			
			    _Result
			 
			```
		lineageTag: bc2fba59-cf9b-43dc-be19-784f8b18f1a8

	measure (%) =
			
			VAR _Act = [Value ACT] * [Annual Factor]
			VAR _UW = [Value UW] * [Annual Factor]
			VAR _Result =
			    IF(
			        OR(_UW = 0, ISBLANK(_UW)),
			        0,
			        DIVIDE(_Act, _UW) - 1
			    )
			RETURN
			    _Result + 0
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: ac4fbf04-9a08-41bc-b536-b6553e1fd928

