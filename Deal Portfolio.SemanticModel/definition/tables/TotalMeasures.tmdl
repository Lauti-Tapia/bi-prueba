	measure '% of GPR' = ```
			
			VAR CurrentItem = SELECTEDVALUE( 'Report Layout'[ ] )
			VAR CurrentRowType = SELECTEDVALUE( 'Report Layout'[RowType] )
			VAR _Revenue_Items = 
			    CALCULATE( SUM( 'Deal Financials'[Amount] ), 'Deal Financials'[Internal Line Item] IN { "Gross Potential Rent", "Loss to Lease" } )
			VAR _Vacancy_Items = 
			    CALCULATE( SUM( 'Deal Financials'[Amount] ), 'Deal Financials'[Internal Line Item] IN { "Vacancy", "Concessions", "Bad Debt Loss" } )
			VAR _Other_Income = 
			    CALCULATE( SUM( 'Deal Financials'[Amount] ), 'Deal Financials'[Internal Line Item] IN { "Utility Income", "Other Income" } )
			VAR _Controllable_OpEx = 
			    CALCULATE( SUM( 'Deal Financials'[Amount] ), 'Deal Financials'[Internal Line Item] IN { "General & Administrative", "Payroll", "Sales & Marketing", "Utilities", "Repairs & Maintenance", "Management Fee", "Turnover" } )
			VAR _Fixed_OpEx = 
			    CALCULATE( SUM( 'Deal Financials'[Amount] ), 'Deal Financials'[Internal Line Item] IN { "Property Taxes", "Insurance" } )
			VAR _Below_NOI = 
			    CALCULATE( SUM( 'Deal Financials'[Amount] ), 'Deal Financials'[Internal Line Item] IN { "CapEx Reserve", "Debt Service" } )
			VAR _Adjusted_GPR = _Revenue_Items
			VAR _Effective_Rental = _Adjusted_GPR + _Vacancy_Items
			VAR _Effective_Gross_Rev = _Effective_Rental + _Other_Income
			VAR _Total_OpEx = _Controllable_OpEx + _Fixed_OpEx
			VAR _NOI = _Effective_Gross_Rev - _Total_OpEx
			VAR _CashFlow = _NOI - _Below_NOI
			VAR _Numerator = 
			    SWITCH( TRUE(),
			        CurrentRowType = "Header", BLANK(),
			        CurrentItem = "Adj. GPR", _Adjusted_GPR,
			        CurrentItem = "Effective Rental Income", _Effective_Rental,
			        CurrentItem = "Effective Gross Revenue", _Effective_Gross_Rev,
			        CurrentItem = "Total Controllable Expenses", _Controllable_OpEx,
			        CurrentItem = "Total Operating Expenses", _Total_OpEx,
			        CurrentItem = "Net Operating Income", _NOI,
			        CurrentItem = "Cash Flow from Operations", _CashFlow,
			        CALCULATE( SUM( 'Deal Financials'[Amount] ), 'Deal Financials'[Internal Line Item] = CurrentItem )
			    )
			VAR _Denominator = 
			    SWITCH( TRUE(),
			        CurrentItem IN { "Gross Potential Rent", "Loss to Lease" }, BLANK(),
			        CurrentRowType = "Header", BLANK(),
			        CurrentItem IN {
			            "Adj. GPR",
			            "Vacancy", 
			            "Concessions", 
			            "Bad Debt Loss",
			            "Effective Rental Income",
			            "Utility Income", 
			            "Other Income",
			            "Effective Gross Revenue"
			        }, _Adjusted_GPR,
			        _Effective_Gross_Rev
			    )
			RETURN
			    DIVIDE( _Numerator, _Denominator, 0 )
			
			
			 
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: a27357dc-16e8-4c80-b1a3-e918760ab1e8

	measure 'Annual Factor' =
			
			DIVIDE(12, [Months In Window], 1)
		formatString: #,0
		lineageTag: d3a0280d-5d45-459a-b9ae-d333024f0ae8

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Debt Yield' = ```
			
			VAR _Conceptos_Suman = { 
			    "Gross Potential Rent", "Loss to Lease", 
			    "Vacancy", "Concessions", "Bad Debt Loss", 
			    "Utility Income", "Other Income" 
			}
			VAR _Conceptos_Restan = { 
			    "General & Administrative", "Payroll", "Sales & Marketing", 
			    "Utilities", "Repairs & Maintenance", "Management Fee", "Turnover",
			    "Property Taxes", "Insurance" 
			}
			VAR _Total_Ingresos = 
			    CALCULATE( SUM( 'Deal Financials'[Amount] ), 'Deal Financials'[Internal Line Item] IN _Conceptos_Suman )
			VAR _Total_Egresos = 
			    CALCULATE( SUM( 'Deal Financials'[Amount] ), 'Deal Financials'[Internal Line Item] IN _Conceptos_Restan )
			VAR _NOI_Raw = _Total_Ingresos - _Total_Egresos
			VAR _FactorForzado = 
			    CALCULATE(
			        [Annual Factor],
			        'View Mode'[Annualize] = "Annualized"
			    )
			VAR _NOI_Annualized = _NOI_Raw * _FactorForzado
			VAR _LoanAmount = 
			    CALCULATE(
			        MAX( 'Deal Financials'[Loan Amount] ),
			        REMOVEFILTERS( 'Deal Financials'[Internal Line Item] )
			    )
			RETURN
			    DIVIDE( _NOI_Annualized, _LoanAmount )
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 82c55eac-ea4e-4aab-81d4-ec47beb93448

	measure DSCR = ```
			
			VAR _Conceptos_Suman_NOI = { 
			    "Gross Potential Rent", "Loss to Lease", 
			    "Vacancy", "Concessions", "Bad Debt Loss", 
			    "Utility Income", "Other Income" 
			}
			VAR _Conceptos_Restan_NOI = { 
			    "General & Administrative", "Payroll", "Sales & Marketing", 
			    "Utilities", "Repairs & Maintenance", "Management Fee", "Turnover",
			    "Property Taxes", "Insurance" 
			}
			VAR _Total_Ingresos = 
			    CALCULATE( SUM( 'Deal Financials'[Amount] ), 'Deal Financials'[Internal Line Item] IN _Conceptos_Suman_NOI )
			VAR _Total_Egresos = 
			    CALCULATE( SUM( 'Deal Financials'[Amount] ), 'Deal Financials'[Internal Line Item] IN _Conceptos_Restan_NOI )
			VAR _NOI = _Total_Ingresos - _Total_Egresos
			VAR _DebtService = 
			    CALCULATE( 
			        SUM( 'Deal Financials'[Amount] ), 
			        'Deal Financials'[Internal Line Item] = "Debt Service" 
			    )
			RETURN
			    DIVIDE( _NOI, ABS(_DebtService) )
			```
		formatString: #,0.00
		lineageTag: 19946370-2623-4283-9271-5d99b8bb7009

