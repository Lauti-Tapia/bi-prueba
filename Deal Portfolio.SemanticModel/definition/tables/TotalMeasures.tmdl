table TotalMeasures
	lineageTag: 67b0ba8f-f2c1-4f05-a47f-dbfbbece0d3c

	measure $ = ```
			
			VAR CurrentItem = SELECTEDVALUE( 'Report Layout'[ ] )
			VAR CurrentRowType = SELECTEDVALUE( 'Report Layout'[RowType] )
			VAR _Revenue_Items =
			    CALCULATE(
			        SUM( 'Deal Financials'[Amount] ),
			        'Deal Financials'[Internal Line Item] IN { "Gross Potential Rent", "Loss to Lease" }
			    )
			VAR _Vacancy_Items =
			    CALCULATE(
			        SUM( 'Deal Financials'[Amount] ),
			        'Deal Financials'[Internal Line Item] IN { "Vacancy", "Concessions", "Bad Debt Loss" }
			    )
			VAR _Other_Income =
			    CALCULATE(
			        SUM( 'Deal Financials'[Amount] ),
			        'Deal Financials'[Internal Line Item] IN { "Utility Income", "Other Income" }
			    )
			VAR _Controllable_OpEx =
			    CALCULATE(
			        SUM( 'Deal Financials'[Amount] ),
			        'Deal Financials'[Internal Line Item]
			            IN {
			                "General & Administrative", "Payroll", "Sales & Marketing", "Utilities",
			                "Repairs & Maintenance", "Management Fee", "Turnover"
			            }
			    )
			VAR _Fixed_OpEx =
			    CALCULATE(
			        SUM( 'Deal Financials'[Amount] ),
			        'Deal Financials'[Internal Line Item] IN { "Property Taxes", "Insurance" }
			    )
			VAR _Below_NOI =
			    CALCULATE(
			        SUM( 'Deal Financials'[Amount] ),
			        'Deal Financials'[Internal Line Item] IN { "CapEx Reserve", "Debt Service" }
			    )
			VAR _Adjusted_GPR = _Revenue_Items
			VAR _Effective_Rental = _Adjusted_GPR + _Vacancy_Items
			VAR _Effective_Gross_Rev = _Effective_Rental + _Other_Income
			VAR _Total_OpEx = _Controllable_OpEx + _Fixed_OpEx
			VAR _NOI = _Effective_Gross_Rev - _Total_OpEx
			VAR _CashFlow = _NOI - _Below_NOI
			VAR _Result =
			    SWITCH(
			        TRUE(),
			        CurrentRowType = "Header", BLANK(),
			        CurrentItem = "Adj. GPR", _Adjusted_GPR,
			        CurrentItem = "Effective Rental Income", _Effective_Rental,
			        CurrentItem = "Effective Gross Revenue", _Effective_Gross_Rev,
			        CurrentItem = "Total Controllable Expenses", _Controllable_OpEx,
			        CurrentItem = "Total Operating Expenses", _Total_OpEx,
			        CurrentItem = "Net Operating Income", _NOI,
			        CurrentItem = "Cash Flow from Operations", _CashFlow,
			        CALCULATE(
			            SUM( 'Deal Financials'[Amount] ),
			            'Deal Financials'[Internal Line Item] = CurrentItem
			        )
			    )
			RETURN
			    _Result * [Annual Factor (Apply)]
			
			 
			```
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 764ef0d1-bd10-433a-a6f0-ff104c6e879c

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

